{
  "name": "readly_magic_webapp",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "server": "cd apps/server && yarn dev",
    "client": "cd apps/client && yarn dev",
    "dev": "concurrently \"yarn server\" \"yarn client\"",
    "build:server": "cd apps/server && yarn build",
    "build:client": "cd apps/client && yarn build",
    "build:all": "concurrently \"yarn build:server\" \"yarn build:client\"",
    "start:server": "cd apps/server && yarn start",
    "start:client": "cd apps/client && yarn start",
    "start:all": "concurrently \"yarn start:server\" \"yarn start:client\""
  },
  "engines": {
    "node": ">=20.0.0 <21.0.0"
  },
  "dependencies": {
    "concurrently": "^9.2.1"
  }
}